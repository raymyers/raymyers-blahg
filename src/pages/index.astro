---
import { getCollection } from "astro:content";
import BaseHead from "../components/BaseHead.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import HomePosts from "../components/HomePosts.astro";
import Tags from "../components/Tags.astro";
import {
  title as SITE_TITLE,
  subtitle as SITE_DESCRIPTION,
} from "../settings/settings.json";
import About from "./about.astro";
import getTags from "../scripts/getTags";

const posts = await getCollection("posts");
const tags = getTags(posts);
---

<!doctype html>
<html lang="en-us">
  <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
  <body>
    <Header title={SITE_TITLE} />
    <main>
      <section class="home-intro" aria-label="Introduction">
        <About />
      </section>

      <section class="home-writing" aria-labelledby="recent-writing">
        <div class="section-heading">
          <h2 id="recent-writing">Recent writing</h2>
        </div>

        <HomePosts allPosts={posts} />
      </section>

      <div class="home-more">
        <section class="home-follow" aria-labelledby="follow-writing">
          <p>
            Prefer a reader? <a href="/rss.xml">Subscribe to the RSS feed</a>.
          </p>
        </section>

        <section class="home-tags" aria-label="Browse by tag">
          <Tags tags={tags} all />
        </section>
      </div>
    </main>
    <Footer />
  </body>
</html>

<style>
  main {
    --home-space-sm: clamp(0.9rem, 0.8rem + 0.5vw, 1.2rem);
    --home-space-md: clamp(1.75rem, 1.42rem + 1.65vw, 2.75rem);
    --home-space-lg: clamp(2rem, 1.68rem + 1.6vw, 3rem);
  }

  .home-intro {
    margin-block-end: var(--home-space-lg);
  }

  .home-writing {
    margin-block-end: var(--home-space-lg);
  }

  .home-more {
    display: grid;
    gap: var(--home-space-md);
    margin-block-start: calc(var(--home-space-sm) * -1);
  }

  .home-follow {
    max-width: 46ch;
  }

  .section-heading {
    margin-block-end: 0.85rem;
  }

  .section-heading h2,
  .home-follow h2 {
    margin: 0;
    color: var(--black);
    font-size: var(--text-headline);
    line-height: 1.15;
    text-align: left;
  }

  .home-writing :global(.posts-list) {
    margin-block: 0;
  }

  .home-writing :global(.post) {
    gap: 0.15rem;
    margin-block-end: 1.35rem;
  }

  .home-writing :global(.post .title) {
    font-size: var(--text-title);
  }

  .home-writing :global(.post-heading time) {
    font-size: 0.95rem;
  }

  .home-writing :global(.post .excerpt) {
    color: var(--transblack);
  }

  .home-follow p {
    margin-block: 0.5rem 0;
  }

  .home-tags :global(.tag-title) {
    margin-block: 0 1rem;
  }

  .home-tags :global(.tags) {
    justify-content: flex-start;
    row-gap: 0.45rem;
  }
</style>
